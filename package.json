{
  "name": "siymon-server-pwa",
  "version": "1.0.0",
  "private": true,
  "description": "siymon ordering PWA + admin dashboard + Wi-Fi ESC/POS printing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "start:prod": "node scripts/prestart.js && node server.js",
    "prestart:prod": "node scripts/prestart.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:studio": "prisma studio",
    "migrate:json2db": "node scripts/migrate-json-to-db.js",
    "webpush:vapid": "node scripts/generate-vapid.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "compression": "^1.8.1",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "dotenv": "^16.4.5",
    "csurf": "^1.11.0",
    "cookie-parser": "^1.4.6",
    "@prisma/client": "^5.0.0",
    "prisma": "^5.0.0",
    "pg": "^8.0.0",
    "redis": "^4.0.0",
    "winston": "^3.13.0",
    "google-auth-library": "^9.10.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {}
}
