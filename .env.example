# Security secrets (REQUIRED in production)
JWT_SECRET=change-this-to-a-long-random-string

# Server
PORT=3000
NODE_ENV=development

# Optional: legacy first-admin password (only used when there are no admins in data/admins.json)
# Prefer creating the first admin using /api/admin/signup, then you can remove this.
ADMIN_PASSWORD=siymon1234

# bcrypt cost factor (8-14 recommended)
BCRYPT_ROUNDS=10

# If behind a reverse proxy (Nginx/Cloudflare/Heroku): set to 1
TRUST_PROXY=1

# Token lifetimes
JWT_ADMIN_EXPIRES_IN=2h
JWT_CUSTOMER_EXPIRES_IN=30d
JWT_DRIVER_EXPIRES_IN=7d
JWT_RESTAURANT_EXPIRES_IN=7d

# Optional CSRF (disabled by default)
ENABLE_CSRF=0

# Optional: force HTTPS (recommended behind Nginx/SSL)
FORCE_HTTPS=0

# Request body limits
# - Default limit applies to all JSON requests
# - IMAGE_BODY_LIMIT applies ONLY to explicit image upload routes
DEFAULT_BODY_LIMIT=1mb
IMAGE_BODY_LIMIT=12mb

# Response compression
# - gzip level: -1..9 (default 6)
# - brotli quality: 0..11 (default 4)
GZIP_LEVEL=6
BROTLI_QUALITY=4

# Image upload limits (bytes)
MAX_MENU_IMAGE_BYTES=2000000
MAX_BANNER_IMAGE_BYTES=2000000
MAX_NOTIFICATION_IMAGE_BYTES=2000000
MAX_TOPUP_RECEIPT_BYTES=3000000
MAX_DRIVER_PROFILE_PHOTO_BYTES=2000000
MAX_DRIVER_ID_IMAGE_BYTES=3500000

# Customer Google Sign-In (optional)
# 1) Create an OAuth Client ID (Web) in Google Cloud Console
# 2) Set the Client ID here (no secret needed on the frontend)
GOOGLE_CLIENT_ID=


# Web Push Notifications (Real Push)
# 1) Generate keys: npm install && npm run webpush:vapid
# 2) Put the keys below
# 3) IMPORTANT: Push requires HTTPS (or localhost).
WEBPUSH_SUBJECT=mailto:admin@siymon.unaux.com
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=

# Wi‑Fi printing hardening
# - By default, printer IP/PORT are taken ONLY from config.json
# - Set WIFI_PRINT_ALLOW_OVERRIDE=1 to allow passing printerIp/printerPort in the request
WIFI_PRINT_ALLOW_OVERRIDE=0

# Refresh tokens
REFRESH_TOKEN_EXPIRES_DAYS=30
REFRESH_TOKENS_MAX=10000
AUDIT_LOG_MAX=5000

# PostgreSQL (for the upcoming DB migration)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/siymon?schema=public

# If you want to enforce DB in production (recommended when Prisma is enabled)
# REQUIRE_DATABASE_URL=1

# Prestart bootstrap (Prisma + json->db)
# - PRISMA_BOOTSTRAP=1 will run: prisma generate + prisma db push + migrate-json-to-db.js
# - AUTO_JSON_MIGRATION=0 to skip json->db on startup
PRISMA_BOOTSTRAP=0
AUTO_JSON_MIGRATION=1

# إذا كنت فعلاً شغّال بـ DB فـ production و باغي تمنع أي كتابة على JSON:
# DISABLE_JSON_WRITES=1

# Redis (optional cache / queues later)
# REDIS_URL=redis://localhost:6379

# CORS (comma-separated origins)
# In development you can leave it empty to allow all.
# In production set it explicitly, e.g.
# CORS_ORIGINS=https://siymon.unaux.com,https://admin.your-domain.com
CORS_ORIGINS=

# Uploads & logs (recommended for VPS/Docker)
# Put uploads outside /public but still served at /uploads
UPLOAD_DIR=./uploads
UPLOADS_PUBLIC_PATH=/uploads
LOG_DIR=./logs

# Rate limiting for admin APIs (/api/admin)
ADMIN_RATE_LIMIT_MAX=600

# Health & metrics
HEALTHCHECK_DB=0
METRICS_ENABLED=0
# METRICS_TOKEN=change-me
